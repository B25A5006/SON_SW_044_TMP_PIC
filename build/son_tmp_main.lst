.................... 
.................... // гГЪгГ™гГХгВІгГ©гГЂгБЃеИЭжЬЯеМЦ (гГФгГ≥гБЃеЗЇеКЫи®≠еЃЪгБ™гБ©)
.................... void io_init(void);
.................... 
.................... // гВҐгГКгГ≠гВ∞гВєгВ§гГГгГБгБЃеИЗгВКжЫњгБИ (0гАЬ3гГБгГ£гГ≥гГНгГЂ)
.................... void switch_channel(uint8_t ch);
