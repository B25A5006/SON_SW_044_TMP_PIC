....................     uint8_t tempData[62];    // жЄ©еЇ¶гГЗгГЉгВњжЬђдљУ (62 Byte = 12bit x 41гГЗгГЉгВњ)
....................     uint8_t crc8;            // CRC-8 (1 Byte)
.................... } TempPacket;
